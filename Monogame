using Microsoft.Xna.Framework;
using Microsoft.Xna.Framework.Graphics;
using Microsoft.Xna.Framework.Input;
using System;

namespace Activity1_Finals
{
    public class Game1 : Game // (game class is inherited)
    {
        private GraphicsDeviceManager _graphics; // provide a way of acccess in graphic device
        private SpriteBatch _spriteBatch; // class that will allow you to display sprite images; core class of displaying images and text
        Texture2D boxTexture, numberTexture;
        int posX, posY, delay;
        float rotation;

        public Game1() //virtual  method ni game class; this is a constructor
        {
            _graphics = new GraphicsDeviceManager(this);
            Content.RootDirectory = "Content";
            IsMouseVisible = true; // visibilty of mouse
            _graphics.PreferredBackBufferWidth = 1000; // sets manually the size of window width
            _graphics.PreferredBackBufferHeight = 600; // sets manually the size of window height
            TargetElapsedTime = TimeSpan.FromSeconds(1f/60f);  // lower fps = unsmooth/babagal; allow you to change the frame per second
            _graphics.IsFullScreen = true; // para full screen yung game

        }

        protected override void Initialize() //method 1 ; initialize field variable that can be used in game logic; initialize game asset
        {
            //pwede rin ilagay dito ung preferredbuffer height and width pero dapat maglagay ng _graphics.ApplyChanges() to implement those change
            posX = 0;
            posY = 200; 
            delay = 0;
            rotation += 1f;

            base.Initialize();
        }

        protected override void LoadContent() // method 2; initialize variables that are used to load game assets; texture, audio
        {
            _spriteBatch = new SpriteBatch(GraphicsDevice);
            boxTexture = Content.Load<Texture2D>("box"); // lagay image name
            numberTexture = Content.Load<Texture2D>("demoimage");

            // TODO: use this.Content to load your game content here
        }

        protected override void Update(GameTime gameTime) // method 3; implements game loop and game logic
        {
            if (GamePad.GetState(PlayerIndex.One).Buttons.Back == ButtonState.Pressed || Keyboard.GetState().IsKeyDown(Keys.Escape))
                Exit();
            posX++; // move from left to right
            posY--; // move up

            /*
            if (posX < 3) {
                posX++;

            }
            else {  posX--; }
            *\

            // certain parts of animation
            if (delay > 60)
            {

                if (posX < 3)
                {
                    posX++;

                }
                else { posX--; }
                delay = 0;
            }
            delay++;


            // TODO: Add your update logic here

            base.Update(gameTime);
        }

        protected override void Draw(GameTime gameTime) // methof 4; draw different images for the game, like rendering; for game loop also
        {
            GraphicsDevice.Clear(Color.CornflowerBlue); // necessary; erase content of previous print; smudge effect pag walang ganto

            // these 2 only works inside draw  method
            _spriteBatch.Begin(); // begin start of drawing

            // use color.white to preserve orig color
            _spriteBatch.Draw(boxTexture, new Rectangle (0, 0, 100, 100), Color.DeepPink); // displacement and shading
            // if want to put sa right side na sagad, minus width to x, if want to put sa right side bot na sagad, minus height to y
            // para sure Window.ClientBounds.Width-100 , Window.ClientBounds.Height-100 (minus x sa width, minus y sa height)
            // to center: Window.ClientBounds.Width/2-50 , Window.ClientBounds.Height/2-50

            _spriteBatch.Draw(boxTexture, new Vector2(20, 100), Color.White); // uses the orig size of image

            _spriteBatch.Draw(boxTexture,
                new Rectangle(20, 20, 150, 150),  //position and size of image in window
                new Rectangle(0, 0, boxTexture.Width, boxTexture.Height),  //  portion of the image to be displayed
                Color.White);

            // nagbabago animations
             new Rectangle(numberTexture.Width/4*posX, 0, numberTexture.Width/4, numberTexture.Height/4),
              Color.White);

            _spriteBatch.Draw(boxTexture,
                new Rectangle(20, 20, 150, 150),
                new Rectangle(0, 0, boxTexture.Width, boxTexture.Height),
                 Color.White, rotation, new Vector2(0,0), SpriteEffects.None, 0);
                //SpriteEffects.FlipHoizontally - finiflip
                //rotation - nirorotate ung image
                // new vector2 -  position of the image


            _spriteBatch.End(); // end the drawing

            // TODO: Add your drawing code here

            base.Draw(gameTime);
        }
    }
}
