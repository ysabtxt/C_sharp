encapsulation n property
using System;
internal class Dog{
  public int age;
  private string color;

  public string Color{ // this is a property
    set{
      if (value == "White" || value == "Brown"){
        color = value;
      }
    }
    get{
        return color;
    }
  }
}

using System;
public class TestDog {
  static void Main(){
      Dog d= new Dog(); 
      d.age = 20;
      d.Color = "White";
      Console.Write(d.age + " " + d.color);
  }
}

