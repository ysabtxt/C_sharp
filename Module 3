class structure
<access modifier> class ClassName{
  <fields> // variable declared inside of a class by the method/constructor ; optional
  <constructor> // optional
  <property> // optional
}

field structure
<access modifier> typeOfData fieldName [value];

property structure
<access modifier> typeOfData PropertyName{ // acessmodifier is private; same typeOfData sa return ng data;
  set{} //assign
  get{}//retrieve value

} //set n get is required

Methods Structure
<access modifier>* returnType MethodName(parameters*){
statements;
}

