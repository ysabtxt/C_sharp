            gt = new List<GameTile>();
            int posX = 0;
            for (int i = 0; i < 2, i++) {
                Rectangle tileDisplay = new Rectangle(posX, Window.ClientBounds.Height - 40, 40, 40); // tile at lower left
                gt.Add(new GameTile(tileTexture, tileDisplay, tileSource, tileColor));
                posX += 40;
            }

            posX = Window.ClientBounds.Width / 2 - 100;
            for (int i = 0; i < 5; i++) {
                Rectangle tileDisplay = new Rectangle(posX, Window.ClientBounds.Height - 160, 40, 40); // tile at center
                gt.Add(new GameTile(tileTexture, tileDisplay, tileSource, tileColor));

            }
