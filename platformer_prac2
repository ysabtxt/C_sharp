        protected override void LoadContent()
        {
            _spriteBatch = new SpriteBatch(GraphicsDevice);

            // TODO: use this.Content to load your game content here
        }

        protected override void Update(GameTime gameTime)
        {
            if (GamePad.GetState(PlayerIndex.One).Buttons.Back == ButtonState.Pressed || Keyboard.GetState().IsKeyDown(Keys.Escape))
                Exit();
            Keys[] k = Keyboard.GetState().GetPressedKeys();
            foreach (Keys key in k) {
                player.PlayerMovement(key);
                break;
            }
            bool checkDrop = true;
            foreach (GameTile tile in gt)
            {
                if (tile.TileDisplay.Intersects(player.PlayerRectangle))
                {

                    checkDrop = false;
                    break;
                }
            }
            if (checkDrop&& !checkJump)
            {
                player.PlayerDrop();
            }
            if (Keyboard.GetState().IsKeyDown(Keys.Space) && !checkJump) {
                jumpCtr = 120;
                checkJump = true;
            }
            if (checkJump)
            {
                --jumpCtr;
                player.PlayerJump();
                if (jumpCtr <= 0) {
                    checkJump = false;
                    jumpCtr = 0;
                }
            
            }
            // TODO: Add your update logic here

            base.Update(gameTime);
        }

        protected override void Draw(GameTime gameTime)
        {
            GraphicsDevice.Clear(Color.CornflowerBlue);
            _spriteBatch.Begin();
            // draww single load: _spriteBatch.Draw(gt.TileTexture, gt.TileSource, gt.TileDisplay, gt.tileColor);

            foreach (GameTile tile in gt)
            {
                _spriteBatch.Draw(tile.TileTexture, tile.TileSource, tile.TileDisplay, tile.TileColor);
            }
            _spriteBatch.Draw(player.PlayerTexture, player.PlayerRectangle, player.PlayerColor);

            _spriteBatch.End();
            // TODO: Add your drawing code here

            base.Draw(gameTime);
        }
    }
}

