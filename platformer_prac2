                                           //gt = new GameTile (tileTexture, tileDisplay, tileSource, tileColor);

            // array: gt = new GameTile[2];
           /* for (int i = 0; i < 2, i++)
            {
                Rectangle tileDisplay = new Rectangle(posX, Window.ClientBounds.Height - 40, 40, 40); // tile at lower left
                gt[i] = new Game(tileColor, tileDisplay, tileSource, tileTexture);
                posX += 40;
