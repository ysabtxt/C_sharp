        protected override void Draw(GameTime gameTime)
        {
            GraphicsDevice.Clear(Color.CornflowerBlue);

            _spriteBatch.Begin();
                _spriteBatch.Draw(boxTexture, boxRectangle, boxColor);
                _spriteBatch.Draw(ballTexture, ballRectangle, ballColor);
            _spriteBatch.End();

            base.Draw(gameTime);
