                new Vector2(0, 0),
                new Vector2(Window.ClientBounds.Width-ballRectangle.Width, //max X n max Y
                Window.ClientBounds.Height-ballRectangle.Height));
            ballRectangle.Location = new Point((int)ballRestriction.X, (int)ballRestriction.Y);
