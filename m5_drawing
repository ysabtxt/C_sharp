        private void DrawingArea(object sender, PaintEventArgs e)
        {
            #region drawing primitives
            // FillRectangle => solid shape; Bruhes => colors the shape
            e.Graphics.FillRectangle(Brushes.Yellow, new Rectangle(10, 10, 100, 50)); 

            //outlines the rectangle
            e.Graphics.DrawRectangle(Pens.Yellow, new Rectangle(10, 70, 100, 50));

            // makes crcle and outlines it
            e.Graphics.FillEllipse(Brushes.Green, new Rectangle(10, 130, 100, 100));
            e.Graphics.DrawEllipse(Pens.Green, new Rectangle(10, 240, 100, 100));

            // makes a pie then ung numbers outside new rectangle nag dedetermine ng hati
            e.Graphics.FillPie(Brushes.Red, new Rectangle(10, 350, 50, 50), 270, 180);

            //outline ng pie na may hati
            e.Graphics.DrawPie(Pens.Red, new Rectangle(10, 350, 50, 50), 270, 180);

            // customized shape, nag coconnect yung mga new point na sinend
            e.Graphics.FillPolygon(Brushed.Red, new Point[] {new Point(200,10), new Point(200,200), new Point(400,200)})
            #endregion

            // style 1
            e.graphics.DrawImage(Image.FromFile("ball2.png"), new Point (10,10));

            //style 2
            e.Graphics.DrawImage(Image.FromFile("ball2.png"), new Rectangle(20, 20, 200, 200));

            // para sumunod sa mouse
            e.Graphics.DrawImage(Image.FromFile("ball2.png"), new Rectangle(posX -75, posY -50, 150, 100));

            //depends sa location ni x at y
            e.graphics.DrawImage(Image.FromFile("ball2.png"), r1));
            
            //style 3
            Image img = image.FromFile("ball 2.png")
            e.Graphics.DrawImage(img.new Rectangle, new Rectangle(20, 20, 200, 150), 
                new Rectangle (0,0,img.Width, img.Height), GraphicsUnit.Pixel);


            // detects if nag ooverlap, pag nag overlap mawawala sya
            if (!r2.IntersectsWith(r1))
            {
                e.Graphics.DrawImage(Image.FromFile("ball2.png"), r2);
            }
            e.Graphics.FillPolygon(Brushes.Yellow,new Point[] {new Point(10,10),
            new Point(10,100),new Point(200,100)});

            // only checks the point
            if (r2.contains(new Point(pos X, pos Y)){
              e.Graphics.DrawImage(Image.FromFile("ball2.png"), r2);
            
            }
            e.Graphics.DrawImage(Image.FromFile("ball1.png"), r1)
        }



        
