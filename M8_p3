using Microsoft.Xna.Framework;
using Microsoft.Xna.Framework.Graphics;
using System;

namespace Bouncing_Ball
{
    internal class Ball
    {
        Texture2D ballTexture;
        Rectangle ballRectangle;
        Color ballColor;
        bool ballDX, ballDY;
        Random rand = new Random();
        public Ball(Texture2D ballTexture, Rectangle ballRectangle, Color ballColor, bool ballDX, bool ballDY)
        {
            this.ballTexture = ballTexture;
            this.ballRectangle = ballRectangle;
            this.ballColor = ballColor;
            this.ballDX = ballDX;
            this.ballDY = ballDY;
        }

        public Texture2D BallTexture { get => ballTexture;  }
        public Rectangle BallRectangle { get => ballRectangle; }
        public Color BallColor { get => ballColor;  }
        public Texture2D BallTexture1 { get => ballTexture; }
        public Rectangle BallRectangle1 { get => ballRectangle; }
        public Color BallColor1 { get => ballColor; set => ballColor = value; }
        public bool BallDX { get => ballDX; set => ballDX = value; }
        public bool BallDY { get => ballDY; set => ballDY = value; }

        public void BallMovement()
        {
            if (ballRectangle.X <= 0)
            {
                ballDX = true;
            }
            else if (ballRectangle.Right >= 800)
            {
                ballDX = false;
            }
            if (ballDX)
            {
                ballRectangle.X += 2;
            }
            else
            {
                ballRectangle.X -= 2;
            }
            if (ballRectangle.Y <= 0)
            {
                ballDY = true;
            }
            else if (ballRectangle.Bottom >= 480)
            {
                ballDY = false;
                //ballColor = Color.White;
            }
            if (ballDY)
            {
                ballRectangle.Y += 2;
            }
            else
            {
                ballRectangle.Y -= 2;
            }
        }

        public void ChangeDirection()
        {
                ballDX = !ballDX;
                ballDY = !ballDY;
                ballColor = new Color(rand.Next(0, 255), rand.Next(0, 255), rand.Next(0, 255));
            BallMovement();
        }
    }
}



